# Copy this file to .env and adjust the values for your environment.
# Do NOT commit your real .env file.

# ── Database ──────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smart_inventory
DB_USERNAME=postgres
DB_PASSWORD=change_me

# ── JWT ───────────────────────────────────────────────────
# Base64-encoded secret; use a strong, random value in production.
JWT_SECRET=change_me_to_a_long_random_base64_secret
# Token lifetime in milliseconds (e.g. 86400000 = 24h).
JWT_EXPIRATION_MS=86400000
